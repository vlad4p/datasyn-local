# Landing zone — raw downloads, scrapes, exports (keep structure only)
data/landing/**
!data/landing/.gitkeep
!data/landing/README.md

# Generated reports and outputs
reports/**
!reports/.gitkeep
output/

*.log
.logs/

# Local data artifacts (outside landing/duckdb)
*.parquet
*.feather
*.arrow

