{
  "mcpServers": {
    "datasyn-duckdb": {
      "command": "uv",
      "args": [
        "run",
        "python",
        "/ABSOLUTE/PATH/TO/datasyn-local/scripts/python/db.py",
        "mcp-serve"
      ],
      "cwd": "/ABSOLUTE/PATH/TO/datasyn-local",
      "env": {
        "DATASYN_DB_PATH": "/ABSOLUTE/PATH/TO/datasyn-local/data/duckdb/datasyn.duckdb"
      }
    }
  }
}
